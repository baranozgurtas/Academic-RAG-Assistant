# ==============================================================================
# ACADEMIC PAPER ASSISTANT - CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# LLM PROVIDER SELECTION
# ------------------------------------------------------------------------------
# Choose your LLM provider: "openai" or "ollama"
# - "openai": Uses OpenAI GPT-4o (requires API key, costs ~$0.01/query)
# - "ollama": Uses local Llama 3.2 (free, runs on your machine)
LLM_PROVIDER=ollama

# ------------------------------------------------------------------------------
# OPENAI SETTINGS (only needed if LLM_PROVIDER=openai)
# ------------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
# Leave empty if using Ollama
OPENAI_API_KEY=

# OpenAI model to use (gpt-4o recommended for best quality)
OPENAI_MODEL=gpt-4o

# ------------------------------------------------------------------------------
# OLLAMA SETTINGS (only needed if LLM_PROVIDER=ollama)
# ------------------------------------------------------------------------------
# Make sure you have installed Ollama and pulled the models:
#   ollama pull llama3.2
#   ollama pull nomic-embed-text

# Ollama model name
OLLAMA_MODEL=llama3.2

# Ollama server URL (default is local)
OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------------------------------------------
# CHROMADB SETTINGS
# ------------------------------------------------------------------------------
# Directory where ChromaDB will store indexed papers
# This folder will be created automatically
CHROMA_PERSIST_DIR=./vectorstore

# ------------------------------------------------------------------------------
# RETRIEVAL SETTINGS
# ------------------------------------------------------------------------------
# Chunk size for splitting PDFs (in tokens)
# Recommended: 1000 (tested vs 500 and 1500)
CHUNK_SIZE=1000

# Overlap between chunks (in tokens)
# Helps preserve context across chunk boundaries
CHUNK_OVERLAP=200

# Number of chunks to retrieve for each query
# Higher = more context but slower
# Recommended: 8 for multi-paper queries
RETRIEVAL_K=8